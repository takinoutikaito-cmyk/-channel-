<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ほむらのゲーム channel - オフィシャルサイト</title>
    <style>
        /* 全体のスタイル（手作りのこだわりとゲームカルチャーを感じるライトテーマ） */
        body {
            font-family: 'Helvetica Neue', Arial, 'Hiragino Kaku Gothic ProN', sans-serif;
            background-color: #f8f9fa;
            color: #1a1a1c;
            margin: 0;
            padding: 0;
            display: flex;
            justify-content: center;
            align-items: flex-start; /* 上端から配置してスクロールできるように変更 */
            min-height: 100vh;
            width: 100vw;
            overflow-x: hidden;
            overflow-y: auto; /* 縦スクロールを有効化 */
            scroll-behavior: smooth; /* ページ内スクロールを滑らかに */
        }
        .container {
            width: 100%;
            max-width: 500px;
            min-height: 100vh; /* 固定高さを廃止し、コンテンツに応じて伸びるように */
            padding: min(24px, 4vmin); 
            padding-top: min(70px, 8vh);
            padding-bottom: min(60px, 8vh); /* 下部に余白を追加 */
            box-sizing: border-box;
            display: flex;
            flex-direction: column;
            justify-content: flex-start; /* 中央寄せから上詰めに変更してスクロール時のガタツキを防ぐ */
            align-items: center;
        }

        /* プロフィール部分 */
        .profile {
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
            width: 100%;
            max-height: 95vh; /* 縦幅に絶対に収める限界線 */
            animation: fadeInUp 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) both;
        }
        
        /* 完璧な円ではなく、人間がフリーハンドで描いたようなわずかに歪んだ愛嬌のあるアバター枠 */
        .avatar {
            width: min(130px, 16vh, 32vmin);
            height: min(130px, 16vh, 32vmin);
            border-radius: 55% 45% 52% 48% / 48% 52% 48% 52%;
            object-fit: contain;
            border: 3px solid #ffffff;
            box-shadow: 4px 4px 0px rgba(0,0,0,0.1);
            background-color: #ffffff;
            margin-bottom: min(15px, 2vh);
            transform: rotate(-1.5deg);
            transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            flex-shrink: 0;
        }
        .avatar:hover {
            transform: rotate(2deg) scale(1.04);
            border-color: #ffffff;
        }

        .info {
            width: 100%;
            flex-shrink: 0;
        }
        .info h1 {
            margin: 0;
            font-size: min(24px, 5.5vmin, 3.5vh);
            white-space: nowrap; /* 文字列を改行せず一列に表示 */
            font-weight: 800;
